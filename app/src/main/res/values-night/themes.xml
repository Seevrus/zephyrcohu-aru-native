<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Boreal" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/input_accent</item>
        <item name="colorPrimaryVariant">@color/neutral</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/blue_400</item>
        <item name="colorSecondaryVariant">@color/blue_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <!-- Splash Screen theme. -->
    <style name="Theme.Boreal.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background_main</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/boreal_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Boreal</item>
    </style>
</resources>